# =============================================================================
#  AI Intraday Trading System — Environment Variables Template
#  Copy this file to `.env` and fill in the values before running.
#  The .env file is loaded by `shared/config.py` at startup.
#
#  ⚠️  SECURITY RULES:
#   1. NEVER commit your .env file — it is in .gitignore.
#   2. NEVER share this file in chat, email, or screenshots.
#   3. All broker credentials are now stored in `broker_credentials.json`
#      (encrypted) via the dashboard UI — do NOT put API keys here.
#   4. Rotate your keys immediately if you suspect they were exposed.
# =============================================================================

# ---------------------------------------------------------------------------
# Broker Credentials
# NOTE: Enter these through the dashboard UI (🔌 Broker Settings), NOT here.
#       They are stored encrypted in broker_credentials.json automatically.
#       The variables below are kept as a fallback for legacy scripts only.
# ---------------------------------------------------------------------------
# FYERS_CLIENT_ID=      ← use dashboard instead
# FYERS_SECRET_KEY=     ← use dashboard instead
# FYERS_REDIRECT_URI=https://localhost

# ---------------------------------------------------------------------------
# Encryption Key (optional — auto-generated if not set)
# ---------------------------------------------------------------------------
# If you want to use a custom Fernet encryption key for broker credentials,
# generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then set it here. Store it securely — losing this key means losing access
# to your saved credentials.
# BROKER_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG only during development — it is very verbose.
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Risk Management (can be overridden from the dashboard Settings panel)
# ---------------------------------------------------------------------------
# Fraction of account equity to risk per trade (1% recommended for beginners)
RISK_PER_TRADE=0.01

# Maximum daily loss as a fraction of equity (5% = stop trading for the day)
DAILY_LOSS_LIMIT=0.05

# Maximum portfolio drawdown before the bot shuts itself off (20%)
MAX_DRAWDOWN=0.20

# ---------------------------------------------------------------------------
# Telegram Alerts (optional)
# ---------------------------------------------------------------------------
# Get your bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Set to true to run the dashboard with HTTPS (requires a certificate)
# DASHBOARD_HTTPS=false

# Maximum orders per minute (prevents runaway loops)
# ORDER_RATE_LIMIT=5

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
# Timezone for display purposes (the system internally uses UTC)
# TIMEZONE=Asia/Kolkata
