# ===========================================================================
#  AI Trading Bot — .gitignore
#  NEVER commit anything in the "SECRETS" sections below.
# ===========================================================================

# ---------------------------------------------------------------------------
# SECRETS — encryption keys & credentials  [NEVER COMMIT]
# ---------------------------------------------------------------------------
.broker.key                   # Fernet encryption key (auto-generated)
broker_credentials.json       # Encrypted broker API keys
dashboard_auth.json           # Hashed dashboard password
.fyers_tokens.json            # Cached Fyers access token
.kite_tokens.json             # Cached Kite access token
*.token
*.key
*.pem
*.p12
*.pfx

# ---------------------------------------------------------------------------
# SECRETS — environment files  [NEVER COMMIT]
# ---------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
# .env.example  ← this IS committed (it's a template, no real values)

# ---------------------------------------------------------------------------
# Runtime state & settings (contain strategy config, may contain paths)
# ---------------------------------------------------------------------------
state.json
settings.json

# ---------------------------------------------------------------------------
# Audit logs (append-only, may contain order details)
# ---------------------------------------------------------------------------
audit/

# ---------------------------------------------------------------------------
# Trained ML models (large binary files)
# ---------------------------------------------------------------------------
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx

# ---------------------------------------------------------------------------
# Data files (historical OHLCV — can be large)
# ---------------------------------------------------------------------------
data/*.csv
data/*.parquet
data/*.feather

# ---------------------------------------------------------------------------
# Python artefacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
MANIFEST

# ---------------------------------------------------------------------------
# IDE / editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Logs (general)
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Jupyter notebooks (may contain sensitive output)
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.dockerignore

# ---------------------------------------------------------------------------
# Temporary / atomic write files
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.orig
