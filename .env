# -------------------------------------------------
# AI Intraday Trading System – environment variables
# -------------------------------------------------
# Copy this file to `.env` and fill in the values before running the
# application. The .env file is read by `shared/config.py`.

# ---------- Fyers API credentials ----------
# Obtain from https://api.fyers.in
FYERS_CLIENT_ID=0KHBQ6IQA4-100
FYERS_SECRET_KEY=ZBUUFDMWZR
# Redirect URI configured in the Fyers developer portal (must match exactly)
FYERS_REDIRECT_URI=https://localhost

# ---------- Logging ----------
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------- Risk management (defaults can be overridden) ----------
# Fraction of account equity to risk per trade (e.g., 0.01 = 1 %)
RISK_PER_TRADE=0.01
# Maximum daily loss as a fraction of equity (e.g., 0.05 = 5 %)
DAILY_LOSS_LIMIT=0.05
# Maximum drawdown allowed (fraction of equity)
MAX_DRAWDOWN=0.20

# ---------- Miscellaneous ----------
# Example: set a custom timezone if you run the bot on a server in a
# different region. The system assumes timestamps are UTC.
# TIMEZONE=Asia/Kolkata
